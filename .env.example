# Copy this file to .env and adjust values as needed

APP_NAME="File Storage Quota Service"
APP_VERSION="1.0.0"
DEBUG=false

# SQLite (default, no setup required)
DATABASE_URL=sqlite+aiosqlite:///./storage_service.db

# PostgreSQL example (uncomment and install asyncpg to use)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/storage_service

# Storage limits (bytes)
DEFAULT_STORAGE_LIMIT_BYTES=104857600   # 100 MB
MAX_STORAGE_LIMIT_BYTES=10737418240     # 10 GB
